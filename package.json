{
  "name": "balatro-save-editor-gui",
  "version": "0.2.3",
  "private": true,
  "description": "Cross-platform GUI for editing Balatro save.jkr files",
  "productName": "Balatro Save Editor",
  "appId": "com.burnttoasters.balatrosaveeditor",
  "desktopName": "com.burnttoasters.balatrosaveeditor.desktop",
  "keywords": [
    "balatro",
    "save-editor",
    "pywebview",
    "cross-platform"
  ],
  "engines": {
    "node": ">=24.x",
    "npm": ">=10.x"
  },
  "scripts": {
    "venv": "node build-scripts/setup-venv.js",
    "dev": "node build-scripts/venv-python.js -m app.main",
    "test": "node build-scripts/venv-python.js -m pytest",
    "smoke:gui": "node build-scripts/venv-python.js build-scripts/smoke-gui.py",
    "licenses": "node build-scripts/licenses.js",
    "prebuild": "npm run licenses",
    "build": "node build-scripts/build.js",
    "smoke:runtime": "node build-scripts/smoke-runtime.js",
    "dist": "node build-scripts/installer.js",
    "dist:mac": "node build-scripts/installer-dmg.js",
    "dist:win": "node build-scripts/installer-nsis.js",
    "dist:linux": "node build-scripts/installer-appimage.js",
    "sign:mac": "dotenv -e .env -- node build-scripts/mac-sign.js",
    "notarize:mac": "dotenv -e .env -- node build-scripts/mac-notarize.js",
    "sign:gpg": "dotenv -e .env -- node build-scripts/gpg-sign.js",
    "publish": "dotenv -e .env -- node build-scripts/publish.js",
    "publish:dry": "node build-scripts/publish.js --dry-run",
    "release:mac": "npm run build && npm run sign:mac && npm run dist:mac && npm run notarize:mac && npm run sign:gpg && npm run publish",
    "release:mac:universal": "cross-env BALATRO_MAC_ARCH=universal2 BALATRO_ARCH=universal npm run release:mac",
    "release:mac:ssh": "bash build-scripts/mac-keychain-ssh.sh && npm run release:mac",
    "release:mac:universal:ssh": "bash build-scripts/mac-keychain-ssh.sh && npm run release:mac:universal",
    "mac:ssh:keychain": "bash build-scripts/mac-keychain-ssh.sh",
    "release:win": "npm run build && npm run dist:win && npm run sign:gpg && npm run publish",
    "release:linux": "npm run build && npm run dist:linux && npm run sign:gpg && npm run publish",
    "bump": "node build-scripts/bump-version.js",
    "sync": "node build-scripts/sync-version.js",
    "clean": "node build-scripts/clean.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BurntToasters/balatro-save-editor-gui.git"
  },
  "author": "BurntToasters <code@rosie.run>",
  "license": "MPL-2.0",
  "bugs": {
    "url": "https://github.com/BurntToasters/balatro-save-editor-gui/issues"
  },
  "homepage": "https://github.com/BurntToasters/balatro-save-editor-gui#readme"
}
