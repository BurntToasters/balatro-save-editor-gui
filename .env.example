# Copy to .env and fill in. Loaded by release scripts via `dotenv -e .env --`.

# --- GitHub release upload (publish) ---
GH_TOKEN=

# --- GPG signing (sign:gpg) ---
GPG_KEY_ID=
GPG_PASSPHRASE=

# --- macOS code signing (sign:mac) ---
# Developer ID Application identity as shown by: security find-identity -v -p codesigning
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# --- macOS notarization (notarize:mac) ---
# Option A: a stored notarytool keychain profile (recommended)
#   xcrun notarytool store-credentials --apple-id ... --team-id ... --password ...
APPLE_KEYCHAIN_PROFILE=
# Option B: Apple ID + app-specific password (used if no keychain profile)
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_PASSWORD=

# --- optional GitHub request tuning ---
# GH_REQUEST_TIMEOUT_MS=30000
# GH_REQUEST_RETRIES=3
# GH_REQUEST_RETRY_DELAY_MS=1500
